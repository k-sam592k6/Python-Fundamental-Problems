def bmi(w,h):
    return w/(h**2)

weight = float(input("Enter your weight(KG):"))
height = float(input("Enter your height(m):"))

result = bmi(weight, height)

if result <18.5:
    print("BMI:", result)
    print("Category: Underweight")
    print("Status: You are below healthy range")
elif result>= 18.5 and result <= 24.9:
    print("BMI:", result)
    print("Category: Normal Weight")
    print("Status: You are in Healthy Range")
elif result >= 25.0 and result <=29.9:
    print("BMI:", result)
    print("Category: Over Weight")
    print("Status: You are above the healthy range ")
elif result >= 30.0 and result <= 34.9:
    print("BMI:", result)
    print("Category: Obese Class 1")
    print("Status: High Health Risk")
elif result >= 35.0 and result <= 39.9:
    print("BMI:", result)
    print("Category: Obese Class 2")
    print("Status: Very High health Risk")
elif result >=40.0:
    print("BMI:", result)
    print("Category: Obese Class 3")
    print("Status: Extreme high health risk")

